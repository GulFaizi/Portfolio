generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Admin {
  id       String @id @default(uuid())
  username String @unique
  password String
}

model Profile {
  id       String @id @default(uuid())
  name     String
  title    String
  summary  String
  location String
  email    String
  linkedin String?
  github   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id          String @id @default(uuid())
  name        String
  category    String // e.g., Frontend, Backend, Tools
  proficiency Int?   // 1-100
}

model Experience {
  id        String   @id @default(uuid())
  company   String
  role      String
  startDate DateTime
  endDate   DateTime? // Null means "Present"
  location  String
  summary   String?   // Brief overview
  details   ExperienceDetail[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExperienceDetail {
  id           String @id @default(uuid())
  description  String // Bullet point text
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
}

model Education {
  id          String @id @default(uuid())
  institution String
  degree      String
  field       String?
  startDate   DateTime?
  endDate     DateTime
  location    String
}

model Project {
  id           String @id @default(uuid())
  title        String
  description  String
  technologies String // Comma separated or JSON
  link         String?
  repoLink     String?
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}
